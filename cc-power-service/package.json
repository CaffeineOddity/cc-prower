{
  "name": "cc-power",
  "version": "1.0.0",
  "description": "Lightweight bridge between Claude Code and chat platforms - Hooks mode only",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js && mkdir -p dist/claude-code-hooks && cp claude-code-hooks/settings.json dist/claude-code-hooks/settings.json && cp claude-code-hooks/stop-hook.sh dist/claude-code-hooks/stop-hook.sh && cp -r providers/templates dist/providers/",
    "dev": "tsx cli.ts start",
    "start": "node dist/cli.js start",
    "cli": "tsx cli.ts",
    "test": "vitest",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "claude",
    "feishu",
    "telegram",
    "whatsapp"
  ],
  "author": "",
  "license": "MIT",
  "bin": {
    "ccpower": "./dist/cli.js"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@types/write-file-atomic": "^4.0.3",
    "chokidar": "^5.0.0",
    "commander": "^13.0.0",
    "eventemitter3": "^5.0.1",
    "node-telegram-bot-api": "^0.66.0",
    "proper-lockfile": "^4.1.2",
    "write-file-atomic": "^6.0.0",
    "ws": "^8.18.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}